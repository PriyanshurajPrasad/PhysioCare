# PhysioCare Backend Environment Variables

# Server Configuration
PORT=4500
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/physiotherapy-clinic

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
JWT_EXPIRE=7d

# Email Configuration (SendGrid)
# IMPORTANT: Replace these with real values for email functionality
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=your-verified-email@example.com
SENDGRID_FROM_NAME=PhysioCare Clinic

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Development Notes:
# - Get SendGrid API Key from: https://app.sendgrid.com/settings/api_keys
# - Verify sender email in SendGrid: https://app.sendgrid.com/settings/sender_auth
# - If SENDGRID_API_KEY is missing, email service will be disabled
# - Appointment creation will work even without email configuration
